{
  "filters": {
    "allowlist": {
      "allow": [
        "/^```[\\s\\S]*?```$/m"
      ]
    }
  },
  "rules": {
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": {
        "space": "always"
      },
      "ja-space-around-code": {
        "before": true,
        "after": true
      }
    },
    "preset-ja-technical-writing": {
      "ja-no-weak-phrase": false,
      "ja-no-mixed-period": {
        "periodMark": "。",
        "allowPeriodMarks": [".", "…"],
        "allowEmojiAtEnd": true
      },
      "sentence-length": {
        "max": 150
      },
      "max-comma": {
        "max": 4
      },
      "no-exclamation-question-mark": false
    }
  }
}
